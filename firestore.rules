rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == "Hidalgo.J.Carlos@gmail.com" && request.auth.token.email_verified == true;
    }
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == "Hidalgo.J.Carlos@gmail.com" && request.auth.token.email_verified == true;
    }
    match /config/{configId} {
      allow read, write: if request.auth != null && request.auth.token.email == "Hidalgo.J.Carlos@gmail.com" && request.auth.token.email_verified == true;
    }
  }
}
